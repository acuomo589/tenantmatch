AI_PROVIDER=openai
OPENAI_API_KEY=
OPEN_API_KEY=

# App + auth
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma / Postgres
DATABASE_URL=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=

AI_ANALYSIS_MODEL=gpt-4.1-mini
AI_LISTING_PARSER_MODEL=o3-mini
AI_WORKBOOK_MODEL=gpt-5.4
AI_OUTREACH_EMAIL_MODEL=gpt-4o
AI_TIMEOUT_MS=30000
AI_USE_MOCK=1
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=timpani-proto

ATTOM_API_KEY=
ATTOM_BASE_URL=https://api.gateway.attomdata.com

APOLLO_API_KEY=

GMAIL_FROM_EMAIL=
GMAIL_ACCESS_TOKEN=

# Frontend local state persistence (listings/workbooks/outreach in browser localStorage)
# 1 = enabled (default), 0 = disabled
NEXT_PUBLIC_LOCAL_PERSISTENCE=1

# Persistence mode for UI workspace state:
# - local  => browser localStorage only
# - server => localStorage + /api/workspace/state file persistence (default)
NEXT_PUBLIC_LOCAL_PERSISTENCE_MODE=server
