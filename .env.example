AI_PROVIDER=openai
OPENAI_API_KEY=
OPEN_API_KEY=

# App + auth
# Optional server-only canonical URL. If unset, NEXT_PUBLIC_APP_URL is used.
APP_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma / Postgres
DATABASE_URL=

# Stripe billing
# Use live keys in production and a matching webhook secret from your deployed Stripe endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional dedicated secret for signed /a/... admin workbook links.
# If unset, the app reuses STRIPE_WEBHOOK_SECRET.
LITE_ADMIN_LINK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=

# TenantMatch
LITE_LINK_PRICE_CENTS=4900
LITE_LINK_CURRENCY=usd
LITE_PREVIEW_ROW_COUNT=1
LITE_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/161c7cx-p6CtXqEkurDzIv7Vc05kbfvqXbhh-6aum58w/edit?gid=0#gid=0
LITE_GOOGLE_SHEET_TAB_NAME=
LITE_GOOGLE_LINKS_TAB_NAME=TenantMatch Links
LITE_ZIP_TARGETS_TAB_NAME=ZIP Targets
LITE_DISCOVERED_LISTINGS_TAB_NAME=Discovered Listings
LITE_QUALIFIED_LISTINGS_TAB_NAME=Qualified Listings
LITE_BROKER_OUTREACH_QUEUE_TAB_NAME=Broker Outreach Queue
LITE_AUTOMATION_RUNS_TAB_NAME=Automation Runs
LITE_DISCOVERY_DAILY_LIMIT=25
LITE_DISCOVERY_MAX_VALIDATIONS_PER_RUN=18
LITE_DISCOVERY_VALIDATION_CONCURRENCY=3
LITE_AUTOMATION_SECRET=
LITE_AUTOMATION_TENANT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

AI_ANALYSIS_MODEL=gpt-4.1-mini
AI_LISTING_PARSER_MODEL=o3-mini
AI_SITE_CONTEXT_MODEL=gpt-5.4
AI_WORKBOOK_MODEL=gpt-5.4
AI_OUTREACH_EMAIL_MODEL=gpt-4o
AI_TIMEOUT_MS=30000
AI_USE_MOCK=1
# Do not enable mock mode in production.
TENANTMATCH_MOCK_AGENTIC_FLOW=0
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tenantmatch

ATTOM_API_KEY=
ATTOM_BASE_URL=https://api.gateway.attomdata.com

APOLLO_API_KEY=

GMAIL_FROM_EMAIL=
GMAIL_SENDER_NAME=Mike at TenantMatch
GMAIL_ACCESS_TOKEN=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# Frontend local state persistence (listings/workbooks/outreach in browser localStorage)
# 1 = enabled (default), 0 = disabled
NEXT_PUBLIC_LOCAL_PERSISTENCE=1

# Persistence mode for UI workspace state:
# - local  => browser localStorage only
# - server => localStorage + /api/workspace/state file persistence (default)
NEXT_PUBLIC_LOCAL_PERSISTENCE_MODE=server
