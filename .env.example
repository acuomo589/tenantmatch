AI_PROVIDER=openai
OPENAI_API_KEY=
OPEN_API_KEY=

# App + auth
# Optional server-only canonical URL. If unset, NEXT_PUBLIC_APP_URL is used.
APP_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma / Postgres
DATABASE_URL=

# Stripe billing
# Use live keys in production and a matching webhook secret from your deployed Stripe endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=

# Timpani Lite
LITE_LINK_PRICE_CENTS=4900
LITE_LINK_CURRENCY=usd
LITE_PREVIEW_ROW_COUNT=1
LITE_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/161c7cx-p6CtXqEkurDzIv7Vc05kbfvqXbhh-6aum58w/edit?gid=0#gid=0
LITE_GOOGLE_SHEET_TAB_NAME=
LITE_GOOGLE_LINKS_TAB_NAME=TenantMatch Links
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

AI_ANALYSIS_MODEL=gpt-4.1-mini
AI_LISTING_PARSER_MODEL=o3-mini
AI_WORKBOOK_MODEL=gpt-5.4
AI_OUTREACH_EMAIL_MODEL=gpt-4o
AI_TIMEOUT_MS=30000
AI_USE_MOCK=1
# Do not enable mock mode in production.
TIMPANI_MOCK_AGENTIC_FLOW=0
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=timpani-proto

ATTOM_API_KEY=
ATTOM_BASE_URL=https://api.gateway.attomdata.com

APOLLO_API_KEY=

GMAIL_FROM_EMAIL=
GMAIL_ACCESS_TOKEN=

# Frontend local state persistence (listings/workbooks/outreach in browser localStorage)
# 1 = enabled (default), 0 = disabled
NEXT_PUBLIC_LOCAL_PERSISTENCE=1

# Persistence mode for UI workspace state:
# - local  => browser localStorage only
# - server => localStorage + /api/workspace/state file persistence (default)
NEXT_PUBLIC_LOCAL_PERSISTENCE_MODE=server
